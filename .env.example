PORT=3001
HOST=0.0.0.0
JWT_SECRET=replace-with-a-long-random-secret
# Comma-separated list of allowed browser origins for cross-origin API access.
# Leave empty when serving the built frontend from the same server.
CORS_ORIGIN=

# Optional bootstrap account for first-time deployments.
BOOTSTRAP_USER_EMAIL=
BOOTSTRAP_USER_PASSWORD=
BOOTSTRAP_USER_NAME=Owner

# Password reset email delivery
APP_BASE_URL=http://localhost:3001
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional AI-written monthly memo
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Optional override when hosting the frontend separately from the API.
VITE_API_BASE_URL=
